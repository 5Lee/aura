# Database
DATABASE_URL="mysql://username:password@localhost:3306/aura_db"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Optional: stronger human verification with Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Optional: distributed auth rate limiting with Upstash Redis REST API
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Optional: override guard secrets used for captcha/login proof signing
AUTH_CAPTCHA_SECRET=""
LOGIN_GUARD_SECRET=""
