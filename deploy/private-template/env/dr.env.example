# Deployment identity
DEPLOY_ENV=dr
AURA_APP_IMAGE=ghcr.io/your-org/aura
APP_IMAGE_TAG=v1.0.0

# App runtime
NEXTAUTH_URL=https://aura-dr.example.com
NEXTAUTH_SECRET=replace_with_64_char_random_secret
FEATURE_FLAG_PRIVATE_DEPLOY=true

# MySQL
MYSQL_ROOT_PASSWORD=replace_with_root_password
MYSQL_DATABASE=aura_db
MYSQL_USER=aura
MYSQL_PASSWORD=replace_with_app_password
DATABASE_URL=mysql://aura:replace_with_app_password@mysql:3306/aura_db
