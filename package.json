{
  "name": "aura-prompt-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:perf": "lhci autorun --config=./lighthouserc.json",
    "preflight": "bash ./tools/preflight-check.sh --mode fast",
    "preflight:fast": "bash ./tools/preflight-check.sh --mode fast",
    "preflight:full": "bash ./tools/preflight-check.sh --mode full",
    "enterprise:preflight": "bash ./tools/enterprise-deploy-preflight.sh --env all --mode fast --skip-docker",
    "enterprise:preflight:full": "bash ./tools/enterprise-deploy-preflight.sh --env all --mode full --skip-docker",
    "lint": "next lint",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "prompt-regression": "tsx tools/prompt-regression.ts",
    "prompt-benchmark": "tsx tools/prompt-performance-benchmark.ts",
    "feature:meta:check": "node tools/check-feature-list-meta.mjs",
    "feature:meta:sync": "node tools/check-feature-list-meta.mjs --write",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "next": "14.2.18",
    "next-auth": "^4.24.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/react": "file:tools/testing/axe-core-react-lite",
    "@playwright/test": "file:tools/testing/playwright-test-lite",
    "@lhci/cli": "file:tools/testing/lhci-cli-lite",
    "@testing-library/jest-dom": "file:tools/testing/jest-dom-lite",
    "@testing-library/react": "file:tools/testing/testing-library-react-lite",
    "@radix-ui/react-label": "file:tools/vendor/radix-react-label-lite",
    "@radix-ui/react-select": "file:tools/vendor/radix-react-select-lite",
    "@radix-ui/react-separator": "file:tools/vendor/radix-react-separator-lite",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8",
    "eslint-config-next": "14.2.18",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "jest": "file:tools/testing/jest-lite",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
