generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String              @id @default(cuid())
  name                   String?
  email                  String              @unique
  password               String
  image                  String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  accounts               Account[]
  favorites              Favorite[]
  prompts                Prompt[]
  collections            PromptCollection[]
  sessions               Session[]
  promptVersionsCreated  PromptVersion[]
  promptAuditLogsCreated PromptAuditLog[]
  promptEvalRunsTriggered PromptEvalRun[]
  promptMemberships      PromptMember[]       @relation("PromptMemberUser")
  promptMemberInvites    PromptMember[]       @relation("PromptMemberInviter")
  subscriptions          Subscription[]
  billingEvents          BillingEvent[]
  invoiceProfile         InvoiceProfile?
  invoices               BillingInvoice[]
}

model Prompt {
  id               String                 @id @default(cuid())
  title            String
  content          String                 @db.Text
  description      String?                @db.Text
  categoryId       String
  isPublic         Boolean                @default(false)
  publishStatus    PromptPublishStatus    @default(DRAFT)
  publishedAt      DateTime?
  sourceExternalId String?                @unique
  authorId         String?
  viewCount        Int                    @default(0)
  favoriteCount    Int                    @default(0)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  favorites        Favorite[]
  author           User?                  @relation(fields: [authorId], references: [id])
  category         Category               @relation(fields: [categoryId], references: [id])
  tags             PromptTag[]
  versions         PromptVersion[]
  auditLogs        PromptAuditLog[]
  templateVariables PromptTemplateVariable[]
  testCases        PromptTestCase[]
  evalRuns         PromptEvalRun[]
  members          PromptMember[]

  @@index([authorId], map: "Prompt_authorId_fkey")
  @@index([categoryId], map: "Prompt_categoryId_fkey")
}

enum PromptPublishStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum PromptRole {
  OWNER
  EDITOR
  REVIEWER
  VIEWER
}

enum PromptVersionSource {
  CREATE
  UPDATE
  ROLLBACK
  IMPORT
}

enum PromptAssertionType {
  CONTAINS
  EQUALS
  REGEX
  JSON_SCHEMA
}

enum PromptEvalRunMode {
  MANUAL
  SCHEDULED
  CI
}

enum PromptEvalRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum BillingProvider {
  MOCKPAY
}

enum BillingEventProcessStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum InvoiceType {
  SUBSCRIPTION
  REFUND
  ADJUSTMENT
}

enum InvoiceStatus {
  ISSUED
  PAID
  REFUNDED
  VOID
}

model PromptVersion {
  id            String              @id @default(cuid())
  promptId      String
  version       Int
  source        PromptVersionSource @default(UPDATE)
  changeSummary String?
  title         String
  content       String              @db.Text
  description   String?             @db.Text
  categoryId    String
  isPublic      Boolean
  tags          Json?
  createdById   String?
  createdAt     DateTime            @default(now())
  prompt        Prompt              @relation(fields: [promptId], references: [id], onDelete: Cascade)
  createdBy     User?               @relation(fields: [createdById], references: [id], onDelete: SetNull)
  evalRuns      PromptEvalRun[]

  @@unique([promptId, version])
  @@index([promptId])
  @@index([createdById])
}

model PromptTemplateVariable {
  id           String   @id @default(cuid())
  promptId     String
  name         String
  type         String   @default("string")
  required     Boolean  @default(false)
  defaultValue String?  @db.Text
  description  String?  @db.Text
  options      Json?
  minLength    Int?
  maxLength    Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  prompt       Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, name])
  @@index([promptId])
}

model PromptAuditLog {
  id        String   @id @default(cuid())
  promptId  String?
  actorId   String?
  action    String
  resource  String   @default("prompt")
  status    String   @default("success")
  metadata  Json?
  createdAt DateTime @default(now())
  prompt    Prompt?  @relation(fields: [promptId], references: [id], onDelete: SetNull)
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([promptId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

model PromptMember {
  id         String     @id @default(cuid())
  promptId   String
  userId     String
  role       PromptRole @default(VIEWER)
  invitedById String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  prompt     Prompt     @relation(fields: [promptId], references: [id], onDelete: Cascade)
  user       User       @relation("PromptMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy  User?      @relation("PromptMemberInviter", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([promptId, userId])
  @@index([promptId])
  @@index([userId])
  @@index([role])
}

model PromptTestCase {
  id             String              @id @default(cuid())
  promptId       String
  name           String
  description    String?             @db.Text
  assertionType  PromptAssertionType
  expectedOutput String              @db.Text
  inputVariables Json?
  enabled        Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  prompt         Prompt              @relation(fields: [promptId], references: [id], onDelete: Cascade)
  results        PromptEvalResult[]

  @@index([promptId])
  @@index([enabled])
}

model PromptEvalRun {
  id               String              @id @default(cuid())
  promptId         String
  promptVersionId  String?
  mode             PromptEvalRunMode   @default(MANUAL)
  status           PromptEvalRunStatus @default(PENDING)
  triggeredById    String?
  summary          String?             @db.Text
  totalCases       Int                 @default(0)
  passedCases      Int                 @default(0)
  failedCases      Int                 @default(0)
  passRate         Float               @default(0)
  averageLatencyMs Int                 @default(0)
  startedAt        DateTime            @default(now())
  finishedAt       DateTime?
  createdAt        DateTime            @default(now())
  prompt           Prompt              @relation(fields: [promptId], references: [id], onDelete: Cascade)
  promptVersion    PromptVersion?      @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)
  triggeredBy      User?               @relation(fields: [triggeredById], references: [id], onDelete: SetNull)
  results          PromptEvalResult[]

  @@index([promptId])
  @@index([promptVersionId])
  @@index([triggeredById])
  @@index([createdAt])
}

model PromptEvalResult {
  id            String        @id @default(cuid())
  runId         String
  testCaseId    String
  passed        Boolean
  latencyMs     Int           @default(0)
  renderedOutput String?      @db.Text
  errorMessage  String?       @db.Text
  details       Json?
  createdAt     DateTime      @default(now())
  run           PromptEvalRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  testCase      PromptTestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([testCaseId])
  @@index([passed])
}

model Subscription {
  id                     String              @id @default(cuid())
  userId                 String
  provider               BillingProvider     @default(MOCKPAY)
  externalCustomerId     String?
  externalSubscriptionId String?             @unique
  planId                 String
  cycle                  BillingCycle        @default(MONTHLY)
  status                 SubscriptionStatus  @default(TRIALING)
  cancelAtPeriodEnd      Boolean             @default(false)
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  canceledAt             DateTime?
  metadata               Json?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  user                   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingEvents          BillingEvent[]
  invoices               BillingInvoice[]

  @@index([userId])
  @@index([status])
  @@index([provider])
}

model BillingEvent {
  id              String                    @id @default(cuid())
  userId          String?
  subscriptionId  String?
  provider        BillingProvider           @default(MOCKPAY)
  providerEventId String
  type            String
  status          BillingEventProcessStatus @default(RECEIVED)
  payload         Json?
  errorMessage    String?                   @db.Text
  receivedAt      DateTime                  @default(now())
  processedAt     DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  user            User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  subscription    Subscription?             @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoices        BillingInvoice[]

  @@unique([provider, providerEventId])
  @@index([subscriptionId])
  @@index([userId])
  @@index([type])
  @@index([status])
}

model InvoiceProfile {
  id            String         @id @default(cuid())
  userId        String         @unique
  title         String
  taxNumber     String
  billingEmail  String?
  address       String?
  phone         String?
  bankName      String?
  bankAccount   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices      BillingInvoice[]

  @@index([taxNumber])
}

model BillingInvoice {
  id                 String      @id @default(cuid())
  invoiceNo          String      @unique
  userId             String
  profileId          String?
  subscriptionId     String?
  billingEventId     String?
  type               InvoiceType @default(SUBSCRIPTION)
  status             InvoiceStatus @default(ISSUED)
  currency           String      @default("CNY")
  subtotalCents      Int
  taxRateBasisPoints Int         @default(600)
  taxCents           Int         @default(0)
  totalCents         Int
  refundedCents      Int         @default(0)
  amountDueCents     Int
  issuedAt           DateTime    @default(now())
  dueAt              DateTime?
  paidAt             DateTime?
  refundedAt         DateTime?
  notes              String?     @db.Text
  metadata           Json?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile            InvoiceProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  subscription       Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  billingEvent       BillingEvent? @relation(fields: [billingEventId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([profileId])
  @@index([subscriptionId])
  @@index([billingEventId])
  @@index([status])
  @@index([type])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  prompts     Prompt[]
}

model Tag {
  id        String      @id @default(cuid())
  name      String      @unique
  slug      String      @unique
  createdAt DateTime    @default(now())
  tags      PromptTag[]
}

model PromptTag {
  promptId String
  tagId    String
  prompt   Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([promptId, tagId])
  @@index([promptId])
  @@index([tagId])
}

model PromptCollection {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId], map: "PromptCollection_userId_fkey")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  promptId  String
  createdAt DateTime @default(now())
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, promptId])
  @@index([promptId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
