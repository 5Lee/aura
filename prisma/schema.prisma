generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String              @id @default(cuid())
  name                   String?
  email                  String              @unique
  password               String
  image                  String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  accounts               Account[]
  favorites              Favorite[]
  prompts                Prompt[]
  collections            PromptCollection[]
  sessions               Session[]
  promptVersionsCreated  PromptVersion[]
  promptAuditLogsCreated PromptAuditLog[]
  promptEvalRunsTriggered PromptEvalRun[]
  promptMemberships      PromptMember[]       @relation("PromptMemberUser")
  promptMemberInvites    PromptMember[]       @relation("PromptMemberInviter")
  subscriptions          Subscription[]
  billingEvents          BillingEvent[]
  invoiceProfile         InvoiceProfile?
  invoices               BillingInvoice[]
  supportTickets         SupportTicket[]      @relation("SupportTicketRequester")
  assignedSupportTickets SupportTicket[]      @relation("SupportTicketAssignee")
  supportTicketEvents    SupportTicketEvent[]
  brandProfile           BrandProfile?
  slaSnapshots           SlaSnapshot[]
  slaAlerts              SlaAlert[]
  ssoProviders           SsoProvider[]
  userIdentities         UserIdentity[]
  directorySyncRuns      DirectorySyncRun[]
  identityConflicts      IdentityConflict[]   @relation("IdentityConflictExistingUser")
  auditRetentionPolicy   AuditRetentionPolicy?
  auditAnomalies         AuditAnomaly[]
}

model Prompt {
  id               String                 @id @default(cuid())
  title            String
  content          String                 @db.Text
  description      String?                @db.Text
  categoryId       String
  isPublic         Boolean                @default(false)
  publishStatus    PromptPublishStatus    @default(DRAFT)
  publishedAt      DateTime?
  sourceExternalId String?                @unique
  authorId         String?
  viewCount        Int                    @default(0)
  favoriteCount    Int                    @default(0)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  favorites        Favorite[]
  author           User?                  @relation(fields: [authorId], references: [id])
  category         Category               @relation(fields: [categoryId], references: [id])
  tags             PromptTag[]
  versions         PromptVersion[]
  auditLogs        PromptAuditLog[]
  templateVariables PromptTemplateVariable[]
  testCases        PromptTestCase[]
  evalRuns         PromptEvalRun[]
  members          PromptMember[]
  auditAnomalies   AuditAnomaly[]

  @@index([authorId], map: "Prompt_authorId_fkey")
  @@index([categoryId], map: "Prompt_categoryId_fkey")
}

enum PromptPublishStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum PromptRole {
  OWNER
  EDITOR
  REVIEWER
  VIEWER
}

enum PromptVersionSource {
  CREATE
  UPDATE
  ROLLBACK
  IMPORT
}

enum PromptAssertionType {
  CONTAINS
  EQUALS
  REGEX
  JSON_SCHEMA
}

enum PromptEvalRunMode {
  MANUAL
  SCHEDULED
  CI
}

enum PromptEvalRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum BillingProvider {
  MOCKPAY
}

enum BillingEventProcessStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum InvoiceType {
  SUBSCRIPTION
  REFUND
  ADJUSTMENT
}

enum InvoiceStatus {
  ISSUED
  PAID
  REFUNDED
  VOID
}

enum SupportTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_USER
  RESOLVED
  CLOSED
}

enum SupportTicketTier {
  COMMUNITY
  STANDARD
  PRIORITY
  DEDICATED
}

enum BrandConfigStatus {
  DRAFT
  PUBLISHED
}

enum SlaMetricType {
  LATENCY
  ERROR_RATE
  AVAILABILITY
}

enum SlaAlertStatus {
  OPEN
  RECOVERED
}

enum SsoProviderType {
  OIDC
  SAML
}

enum SsoProviderStatus {
  DISABLED
  ACTIVE
}

enum IdentitySource {
  LOCAL
  OIDC
  SAML
}

enum DirectorySyncStatus {
  SUCCESS
  PARTIAL
  FAILED
}

enum IdentityConflictStatus {
  OPEN
  RESOLVED
}

enum AuditRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model PromptVersion {
  id            String              @id @default(cuid())
  promptId      String
  version       Int
  source        PromptVersionSource @default(UPDATE)
  changeSummary String?
  title         String
  content       String              @db.Text
  description   String?             @db.Text
  categoryId    String
  isPublic      Boolean
  tags          Json?
  createdById   String?
  createdAt     DateTime            @default(now())
  prompt        Prompt              @relation(fields: [promptId], references: [id], onDelete: Cascade)
  createdBy     User?               @relation(fields: [createdById], references: [id], onDelete: SetNull)
  evalRuns      PromptEvalRun[]

  @@unique([promptId, version])
  @@index([promptId])
  @@index([createdById])
}

model PromptTemplateVariable {
  id           String   @id @default(cuid())
  promptId     String
  name         String
  type         String   @default("string")
  required     Boolean  @default(false)
  defaultValue String?  @db.Text
  description  String?  @db.Text
  options      Json?
  minLength    Int?
  maxLength    Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  prompt       Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, name])
  @@index([promptId])
}

model PromptAuditLog {
  id             String         @id @default(cuid())
  promptId       String?
  actorId        String?
  action         String
  resource       String         @default("prompt")
  status         String         @default("success")
  riskLevel      AuditRiskLevel @default(LOW)
  requestId      String?
  actorEmail     String?
  ipHash         String?
  userAgent      String?
  previousHash   String?
  entryHash      String?        @unique
  immutable      Boolean        @default(true)
  retentionUntil DateTime?
  metadata       Json?
  createdAt      DateTime       @default(now())
  prompt         Prompt?        @relation(fields: [promptId], references: [id], onDelete: SetNull)
  actor          User?          @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([promptId])
  @@index([actorId])
  @@index([action])
  @@index([riskLevel])
  @@index([requestId])
  @@index([retentionUntil])
  @@index([entryHash])
  @@index([createdAt])
}

model PromptMember {
  id         String     @id @default(cuid())
  promptId   String
  userId     String
  role       PromptRole @default(VIEWER)
  invitedById String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  prompt     Prompt     @relation(fields: [promptId], references: [id], onDelete: Cascade)
  user       User       @relation("PromptMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy  User?      @relation("PromptMemberInviter", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([promptId, userId])
  @@index([promptId])
  @@index([userId])
  @@index([role])
}

model PromptTestCase {
  id             String              @id @default(cuid())
  promptId       String
  name           String
  description    String?             @db.Text
  assertionType  PromptAssertionType
  expectedOutput String              @db.Text
  inputVariables Json?
  enabled        Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  prompt         Prompt              @relation(fields: [promptId], references: [id], onDelete: Cascade)
  results        PromptEvalResult[]

  @@index([promptId])
  @@index([enabled])
}

model PromptEvalRun {
  id               String              @id @default(cuid())
  promptId         String
  promptVersionId  String?
  mode             PromptEvalRunMode   @default(MANUAL)
  status           PromptEvalRunStatus @default(PENDING)
  triggeredById    String?
  summary          String?             @db.Text
  totalCases       Int                 @default(0)
  passedCases      Int                 @default(0)
  failedCases      Int                 @default(0)
  passRate         Float               @default(0)
  averageLatencyMs Int                 @default(0)
  startedAt        DateTime            @default(now())
  finishedAt       DateTime?
  createdAt        DateTime            @default(now())
  prompt           Prompt              @relation(fields: [promptId], references: [id], onDelete: Cascade)
  promptVersion    PromptVersion?      @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)
  triggeredBy      User?               @relation(fields: [triggeredById], references: [id], onDelete: SetNull)
  results          PromptEvalResult[]

  @@index([promptId])
  @@index([promptVersionId])
  @@index([triggeredById])
  @@index([createdAt])
}

model PromptEvalResult {
  id            String        @id @default(cuid())
  runId         String
  testCaseId    String
  passed        Boolean
  latencyMs     Int           @default(0)
  renderedOutput String?      @db.Text
  errorMessage  String?       @db.Text
  details       Json?
  createdAt     DateTime      @default(now())
  run           PromptEvalRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  testCase      PromptTestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([testCaseId])
  @@index([passed])
}

model Subscription {
  id                     String              @id @default(cuid())
  userId                 String
  provider               BillingProvider     @default(MOCKPAY)
  externalCustomerId     String?
  externalSubscriptionId String?             @unique
  planId                 String
  cycle                  BillingCycle        @default(MONTHLY)
  status                 SubscriptionStatus  @default(TRIALING)
  cancelAtPeriodEnd      Boolean             @default(false)
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  canceledAt             DateTime?
  metadata               Json?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  user                   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingEvents          BillingEvent[]
  invoices               BillingInvoice[]

  @@index([userId])
  @@index([status])
  @@index([provider])
}

model BillingEvent {
  id              String                    @id @default(cuid())
  userId          String?
  subscriptionId  String?
  provider        BillingProvider           @default(MOCKPAY)
  providerEventId String
  type            String
  status          BillingEventProcessStatus @default(RECEIVED)
  payload         Json?
  errorMessage    String?                   @db.Text
  receivedAt      DateTime                  @default(now())
  processedAt     DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  user            User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  subscription    Subscription?             @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoices        BillingInvoice[]

  @@unique([provider, providerEventId])
  @@index([subscriptionId])
  @@index([userId])
  @@index([type])
  @@index([status])
}

model InvoiceProfile {
  id            String         @id @default(cuid())
  userId        String         @unique
  title         String
  taxNumber     String
  billingEmail  String?
  address       String?
  phone         String?
  bankName      String?
  bankAccount   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices      BillingInvoice[]

  @@index([taxNumber])
}

model BillingInvoice {
  id                 String      @id @default(cuid())
  invoiceNo          String      @unique
  userId             String
  profileId          String?
  subscriptionId     String?
  billingEventId     String?
  type               InvoiceType @default(SUBSCRIPTION)
  status             InvoiceStatus @default(ISSUED)
  currency           String      @default("CNY")
  subtotalCents      Int
  taxRateBasisPoints Int         @default(600)
  taxCents           Int         @default(0)
  totalCents         Int
  refundedCents      Int         @default(0)
  amountDueCents     Int
  issuedAt           DateTime    @default(now())
  dueAt              DateTime?
  paidAt             DateTime?
  refundedAt         DateTime?
  notes              String?     @db.Text
  metadata           Json?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile            InvoiceProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  subscription       Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  billingEvent       BillingEvent? @relation(fields: [billingEventId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([profileId])
  @@index([subscriptionId])
  @@index([billingEventId])
  @@index([status])
  @@index([type])
}

model SupportTicket {
  id               String               @id @default(cuid())
  ticketNo         String               @unique
  userId           String
  assigneeId       String?
  title            String
  description      String               @db.Text
  category         String               @default("general")
  planId           String               @default("free")
  tier             SupportTicketTier    @default(COMMUNITY)
  priority         SupportTicketPriority @default(NORMAL)
  status           SupportTicketStatus  @default(OPEN)
  firstResponseAt  DateTime?
  responseDueAt    DateTime?
  resolvedAt       DateTime?
  closedAt         DateTime?
  metadata         Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  user             User                 @relation("SupportTicketRequester", fields: [userId], references: [id], onDelete: Cascade)
  assignee         User?                @relation("SupportTicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  events           SupportTicketEvent[]

  @@index([userId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([tier])
}

model SupportTicketEvent {
  id             String              @id @default(cuid())
  ticketId       String
  actorId        String
  action         String
  fromStatus     SupportTicketStatus?
  toStatus       SupportTicketStatus?
  note           String?             @db.Text
  metadata       Json?
  createdAt      DateTime            @default(now())
  ticket         SupportTicket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor          User                @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

model BrandProfile {
  id              String           @id @default(cuid())
  userId          String           @unique
  status          BrandConfigStatus @default(DRAFT)
  draftConfig     Json?
  publishedConfig Json?
  publishedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model SlaSnapshot {
  id               String   @id @default(cuid())
  userId           String
  planId           String   @default("free")
  windowStart      DateTime
  windowEnd        DateTime
  availabilityRate Float    @default(100)
  errorRate        Float    @default(0)
  latencyP95Ms     Int      @default(0)
  totalChecks      Int      @default(0)
  failedChecks     Int      @default(0)
  metadata         Json?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([windowEnd])
  @@index([planId])
}

model SlaAlert {
  id         String         @id @default(cuid())
  userId     String
  metric     SlaMetricType
  status     SlaAlertStatus @default(OPEN)
  threshold  Float
  observed   Float
  summary    String         @db.Text
  triggeredAt DateTime      @default(now())
  recoveredAt DateTime?
  metadata   Json?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([metric])
  @@index([status])
  @@index([triggeredAt])
}

model SsoProvider {
  id                 String            @id @default(cuid())
  userId             String
  type               SsoProviderType   @default(OIDC)
  status             SsoProviderStatus @default(DISABLED)
  name               String
  issuerUrl          String
  ssoUrl             String?
  clientId           String?
  clientSecret       String?
  domains            Json?
  roleMapping        Json?
  defaultRole        String            @default("VIEWER")
  enforceSso         Boolean           @default(false)
  allowLocalFallback Boolean           @default(true)
  metadata           Json?
  lastSyncedAt       DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  identities         UserIdentity[]
  syncRuns           DirectorySyncRun[]
  conflicts          IdentityConflict[]

  @@index([userId])
  @@index([status])
  @@index([type])
}

model UserIdentity {
  id             String         @id @default(cuid())
  userId         String
  providerId     String?
  source         IdentitySource @default(LOCAL)
  externalUserId String
  email          String
  displayName    String?
  role           String         @default("VIEWER")
  metadata       Json?
  lastLoginAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       SsoProvider?   @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@unique([source, externalUserId])
  @@index([userId])
  @@index([providerId])
  @@index([email])
}

model DirectorySyncRun {
  id           String              @id @default(cuid())
  providerId   String
  actorId      String
  status       DirectorySyncStatus @default(SUCCESS)
  summary      String?             @db.Text
  totalUsers   Int                 @default(0)
  createdUsers Int                 @default(0)
  linkedUsers  Int                 @default(0)
  conflictCount Int                @default(0)
  startedAt    DateTime            @default(now())
  finishedAt   DateTime?
  metadata     Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  provider     SsoProvider         @relation(fields: [providerId], references: [id], onDelete: Cascade)
  actor        User                @relation(fields: [actorId], references: [id], onDelete: Cascade)
  conflicts    IdentityConflict[]

  @@index([providerId])
  @@index([actorId])
  @@index([status])
  @@index([startedAt])
}

model IdentityConflict {
  id             String                 @id @default(cuid())
  providerId     String
  syncRunId      String?
  externalUserId String
  incomingEmail  String
  incomingName   String?
  existingUserId String
  reason         String                 @db.Text
  status         IdentityConflictStatus @default(OPEN)
  metadata       Json?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  provider       SsoProvider            @relation(fields: [providerId], references: [id], onDelete: Cascade)
  syncRun        DirectorySyncRun?      @relation(fields: [syncRunId], references: [id], onDelete: SetNull)
  existingUser   User                   @relation("IdentityConflictExistingUser", fields: [existingUserId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([syncRunId])
  @@index([existingUserId])
  @@index([status])
}

model AuditRetentionPolicy {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  retentionDays           Int      @default(365)
  exportEnabled           Boolean  @default(true)
  failureBurstThreshold   Int      @default(5)
  multiIpBurstThreshold   Int      @default(3)
  sensitiveBurstThreshold Int      @default(8)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditAnomaly {
  id          String         @id @default(cuid())
  userId      String
  promptId    String?
  type        String
  status      String         @default("OPEN")
  severity    AuditRiskLevel @default(MEDIUM)
  summary     String         @db.Text
  matchedRule String
  occurrences Int            @default(1)
  firstSeenAt DateTime       @default(now())
  lastSeenAt  DateTime       @default(now())
  metadata    Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt      Prompt?        @relation(fields: [promptId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([promptId])
  @@index([type])
  @@index([status])
  @@index([severity])
  @@index([lastSeenAt])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  prompts     Prompt[]
}

model Tag {
  id        String      @id @default(cuid())
  name      String      @unique
  slug      String      @unique
  createdAt DateTime    @default(now())
  tags      PromptTag[]
}

model PromptTag {
  promptId String
  tagId    String
  prompt   Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([promptId, tagId])
  @@index([promptId])
  @@index([tagId])
}

model PromptCollection {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId], map: "PromptCollection_userId_fkey")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  promptId  String
  createdAt DateTime @default(now())
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, promptId])
  @@index([promptId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
